{
  "version": "1.0.0",
  "description": "时间表达模板库 - 覆盖中英文各种时间表达方式",
  "last_updated": "2026-02-24",
  "categories": {
    "year": {
      "description": "年份表达",
      "granularity": "YEAR",
      "templates": [
        { "expression": "2025年", "parsed": { "year": "2025" } },
        { "expression": "2025年度", "parsed": { "year": "2025" } },
        { "expression": "2025年1月1日到2025年12月31日", "parsed": { "year": "2025", "start": "2025-01-01", "end": "2025-12-31" } },
        { "expression": "2024年", "parsed": { "year": "2024" } },
        { "expression": "2024年度", "parsed": { "year": "2024" } },
        { "expression": "2026年", "parsed": { "year": "2026" } },
        { "expression": "2026年度", "parsed": { "year": "2026" } },
        { "expression": "in 2025", "parsed": { "year": "2025" } },
        { "expression": "year 2025", "parsed": { "year": "2025" } },
        { "expression": "CY2025", "parsed": { "year": "2025" } },
        { "expression": "FY2025", "parsed": { "year": "2025", "fiscal": true } },
        { "expression": "今年", "parsed": { "relative": "current_year" } },
        { "expression": "去年", "parsed": { "relative": "last_year" } },
        { "expression": "明年", "parsed": { "relative": "next_year" } },
        { "expression": "前年", "parsed": { "relative": "year_before_last" } },
        { "expression": "後年", "parsed": { "relative": "year_after_next" } },
        { "expression": "上一年", "parsed": { "relative": "last_year" } },
        { "expression": "下一年", "parsed": { "relative": "next_year" } },
        { "expression": "last year", "parsed": { "relative": "last_year" } },
        { "expression": "next year", "parsed": { "relative": "next_year" } },
        { "expression": "this year", "parsed": { "relative": "current_year" } }
      ]
    },
    "month": {
      "description": "月份表达",
      "granularity": "MONTH",
      "templates": [
        { "expression": "1月", "parsed": { "month": "01" } },
        { "expression": "01月", "parsed": { "month": "01" } },
        { "expression": "1月份", "parsed": { "month": "01" } },
        { "expression": "01月份", "parsed": { "month": "01" } },
        { "expression": "2月", "parsed": { "month": "02" } },
        { "expression": "3月", "parsed": { "month": "03" } },
        { "expression": "4月", "parsed": { "month": "04" } },
        { "expression": "5月", "parsed": { "month": "05" } },
        { "expression": "6月", "parsed": { "month": "06" } },
        { "expression": "7月", "parsed": { "month": "07" } },
        { "expression": "8月", "parsed": { "month": "08" } },
        { "expression": "9月", "parsed": { "month": "09" } },
        { "expression": "10月", "parsed": { "month": "10" } },
        { "expression": "11月", "parsed": { "month": "11" } },
        { "expression": "12月", "parsed": { "month": "12" } },
        { "expression": "January", "parsed": { "month": "01" } },
        { "expression": "Jan", "parsed": { "month": "01" } },
        { "expression": "February", "parsed": { "month": "02" } },
        { "expression": "Feb", "parsed": { "month": "02" } },
        { "expression": "March", "parsed": { "month": "03" } },
        { "expression": "Mar", "parsed": { "month": "03" } },
        { "expression": "April", "parsed": { "month": "04" } },
        { "expression": "Apr", "parsed": { "month": "04" } },
        { "expression": "May", "parsed": { "month": "05" } },
        { "expression": "June", "parsed": { "month": "06" } },
        { "expression": "Jun", "parsed": { "month": "06" } },
        { "expression": "July", "parsed": { "month": "07" } },
        { "expression": "Jul", "parsed": { "month": "07" } },
        { "expression": "August", "parsed": { "month": "08" } },
        { "expression": "Aug", "parsed": { "month": "08" } },
        { "expression": "September", "parsed": { "month": "09" } },
        { "expression": "Sep", "parsed": { "month": "09" } },
        { "expression": "October", "parsed": { "month": "10" } },
        { "expression": "Oct", "parsed": { "month": "10" } },
        { "expression": "November", "parsed": { "month": "11" } },
        { "expression": "Nov", "parsed": { "month": "11" } },
        { "expression": "December", "parsed": { "month": "12" } },
        { "expression": "Dec", "parsed": { "month": "12" } },
        { "expression": "上个月", "parsed": { "relative": "last_month" } },
        { "expression": "下个月", "parsed": { "relative": "next_month" } },
        { "expression": "这个月", "parsed": { "relative": "current_month" } },
        { "expression": "last month", "parsed": { "relative": "last_month" } },
        { "expression": "next month", "parsed": { "relative": "next_month" } },
        { "expression": "this month", "parsed": { "relative": "current_month" } },
        { "expression": "month 1", "parsed": { "month": "01" } }
      ]
    },
    "year_month": {
      "description": "年/月组合表达",
      "granularity": "YEAR_MONTH",
      "templates": [
        { "expression": "2025年1月", "parsed": { "year": "2025", "month": "01" } },
        { "expression": "2025年01月", "parsed": { "year": "2025", "month": "01" } },
        { "expression": "2025-01", "parsed": { "year": "2025", "month": "01" } },
        { "expression": "2025/01", "parsed": { "year": "2025", "month": "01" } },
        { "expression": "2025年2月", "parsed": { "year": "2025", "month": "02" } },
        { "expression": "2025年3月", "parsed": { "year": "2025", "month": "03" } },
        { "expression": "2025年12月", "parsed": { "year": "2025", "month": "12" } },
        { "expression": "2024年1月", "parsed": { "year": "2024", "month": "01" } },
        { "expression": "2026年1月", "parsed": { "year": "2026", "month": "01" } },
        { "expression": "January 2025", "parsed": { "year": "2025", "month": "01" } },
        { "expression": "Jan 2025", "parsed": { "year": "2025", "month": "01" } },
        { "expression": "2025 January", "parsed": { "year": "2025", "month": "01" } },
        { "expression": "2025-01-01", "parsed": { "year": "2025", "month": "01", "day": "01" } },
        { "expression": "2025/01/01", "parsed": { "year": "2025", "month": "01", "day": "01" } },
        { "expression": "2025.01.01", "parsed": { "year": "2025", "month": "01", "day": "01" } }
      ]
    },
    "date_range": {
      "description": "日期范围表达",
      "granularity": "RANGE",
      "templates": [
        { "expression": "最近7天", "parsed": { "relative": "last_7_days" } },
        { "expression": "最近一周", "parsed": { "relative": "last_7_days" } },
        { "expression": "最近30天", "parsed": { "relative": "last_30_days" } },
        { "expression": "最近一个月", "parsed": { "relative": "last_30_days" } },
        { "expression": "最近三个月", "parsed": { "relative": "last_90_days" } },
        { "expression": "最近半年", "parsed": { "relative": "last_180_days" } },
        { "expression": "最近一年", "parsed": { "relative": "last_365_days" } },
        { "expression": "最近N天", "parsed": { "relative": "last_n_days", "note": "需要提取N的值" } },
        { "expression": "from 2025-01-01 to 2025-12-31", "parsed": { "start": "2025-01-01", "end": "2025-12-31" } },
        { "expression": "between 2025-01-01 and 2025-12-31", "parsed": { "start": "2025-01-01", "end": "2025-12-31" } },
        { "expression": "2025-01-01 ~ 2025-12-31", "parsed": { "start": "2025-01-01", "end": "2025-12-31" } },
        { "expression": "last 7 days", "parsed": { "relative": "last_7_days" } },
        { "expression": "past week", "parsed": { "relative": "last_7_days" } },
        { "expression": "last 30 days", "parsed": { "relative": "last_30_days" } },
        { "expression": "last month", "parsed": { "relative": "last_30_days" } },
        { "expression": "past month", "parsed": { "relative": "last_30_days" } },
        { "expression": "last 3 months", "parsed": { "relative": "last_90_days" } },
        { "expression": "past 3 months", "parsed": { "relative": "last_90_days" } },
        { "expression": "last year", "parsed": { "relative": "last_365_days" } },
        { "expression": "past year", "parsed": { "relative": "last_365_days" } },
        { "expression": "Q1 2025", "parsed": { "year": "2025", "quarter": "Q1" } },
        { "expression": "Q2 2025", "parsed": { "year": "2025", "quarter": "Q2" } },
        { "expression": "Q3 2025", "parsed": { "year": "2025", "quarter": "Q3" } },
        { "expression": "Q4 2025", "parsed": { "year": "2025", "quarter": "Q4" } },
        { "expression": "2025 Q1", "parsed": { "year": "2025", "quarter": "Q1" } },
        { "expression": "2025 Q2", "parsed": { "year": "2025", "quarter": "Q2" } },
        { "expression": "第一季度", "parsed": { "quarter": "Q1" } },
        { "expression": "第二季度", "parsed": { "quarter": "Q2" } },
        { "expression": "第三季度", "parsed": { "quarter": "Q3" } },
        { "expression": "第四季度", "parsed": { "quarter": "Q4" } },
        { "expression": "上半年", "parsed": { "half": "first" } },
        { "expression": "下半年", "parsed": { "half": "second" } },
        { "expression": "年初", "parsed": { "relative": "year_start" } },
        { "expression": "年末", "parsed": { "relative": "year_end" } },
        { "expression": "月初", "parsed": { "relative": "month_start" } },
        { "expression": "月末", "parsed": { "relative": "month_end" } },
        { "expression": "today", "parsed": { "relative": "today" } },
        { "expression": "yesterday", "parsed": { "relative": "yesterday" } },
        { "expression": "tomorrow", "parsed": { "relative": "tomorrow" } },
        { "expression": "今天", "parsed": { "relative": "today" } },
        { "expression": "昨天", "parsed": { "relative": "yesterday" } },
        { "expression": "明天", "parsed": { "relative": "tomorrow" } },
        { "expression": "本周", "parsed": { "relative": "this_week" } },
        { "expression": "上周", "parsed": { "relative": "last_week" } },
        { "expression": "下周", "parsed": { "relative": "next_week" } },
        { "expression": "this week", "parsed": { "relative": "this_week" } },
        { "expression": "last week", "parsed": { "relative": "last_week" } },
        { "expression": "next week", "parsed": { "relative": "next_week" } }
      ]
    },
    "decade": {
      "description": "年代表达",
      "granularity": "DECADE",
      "templates": [
        { "expression": "2020年代", "parsed": { "decade": "2020" } },
        { "expression": "2020s", "parsed": { "decade": "2020" } },
        { "expression": "21世纪", "parsed": { "century": 21 } },
        { "expression": "20世纪", "parsed": { "century": 20 } },
        { "expression": "the 2020s", "parsed": { "decade": "2020" } }
      ]
    }
  },
  "notes": {
    "relative_keywords": {
      "current_year": "当前年份",
      "last_year": "上一年",
      "next_year": "下一年",
      "year_before_last": "前年",
      "year_after_next": "后年",
      "current_month": "当前月份",
      "last_month": "上个月",
      "next_month": "下个月",
      "last_7_days": "最近7天",
      "last_30_days": "最近30天",
      "last_90_days": "最近3个月",
      "last_180_days": "最近半年",
      "last_365_days": "最近一年",
      "today": "今天",
      "yesterday": "昨天",
      "tomorrow": "明天",
      "this_week": "本周",
      "last_week": "上周",
      "next_week": "下周",
      "year_start": "年初",
      "year_end": "年末",
      "month_start": "月初",
      "month_end": "月末"
    }
  }
}
