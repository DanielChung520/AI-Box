    "priority_rules": {
      "description": "意圖優先級規則 - 混合意圖時的處理邏輯",
      "business_priority": "當混合 GREETING/THANKS/CHITCHAT/GENERAL_QA 與 BUSINESS_QUERY/BUSINESS_ACTION 時，以業務意圖為優先",
      "examples": [
        {
          "input": "你好，幫我查詢料號庫存",
          "expected_intent": "BUSINESS_QUERY",
          "reason": "混合問候與業務，以業務為優先"
        },
        {
          "input": "謝謝，我想查庫存",
          "expected_intent": "BUSINESS_QUERY",
          "reason": "混合感謝與業務，以業務為優先"
        }
      ]
    }
